{
  "name": "desktop",
  "version": "1.0.0",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently \"tsc --watch\" \"electron dist/main.js\"",
    "build": "tsc",
    "start": "electron dist/main.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codepilot/shared": "workspace:*",
    "@codepilot/editor-sdk": "workspace:*",
    "electron": "^28.1.0",
    "monaco-editor": "^0.45.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  }
}
