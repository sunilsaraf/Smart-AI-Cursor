# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://codepilot:codepilot@localhost:5432/codepilot
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Cohere (for reranking)
COHERE_API_KEY=

# Vector Database (pgvector)
VECTOR_DIMENSIONS=1536

# Object Storage (MinIO/S3)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=codepilot
MINIO_USE_SSL=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Embedding
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=100
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Chat Models
CHAT_MODEL_DEFAULT=gpt-4-turbo-preview
CHAT_MODEL_FAST=gpt-3.5-turbo
CHAT_MODEL_REASONING=claude-3-opus-20240229

# Code Models
CODE_MODEL_EDIT=gpt-4-turbo-preview
CODE_MODEL_REVIEW=gpt-4-turbo-preview

# Feature Flags
FEATURE_AGENTS_ENABLED=true
FEATURE_TERMINAL_ENABLED=true
FEATURE_VOICE_ENABLED=false

# Monitoring
SENTRY_DSN=
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3001

# Worker
WORKER_CONCURRENCY=5
WORKER_MAX_JOB_ATTEMPTS=3

# Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@codepilot.dev
